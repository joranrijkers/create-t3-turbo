# =============================================================================
# Prikkr — Environment Variables Example
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# Database (Supabase PostgreSQL)
# IMPORTANT: Use the TRANSACTION POOLER URL (port 6543), not the direct connection (5432).
# The app uses @vercel/postgres which requires a pooled connection.
# Supabase: Project Settings → Database → Connection string → "Transaction" pooler → URI
POSTGRES_URL="postgres://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"

# Better Auth secret — generate with: openssl rand -base64 32
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# The base URL of the web app (no trailing slash)
# For magic link on a real device: set this to your machine's LAN IP so the phone can open the link
# and the auth callback uses the same host (e.g. http://10.69.2.171:3000). Find your IP: macOS/Linux
# `ifconfig | grep "inet "` or Windows `ipconfig`. Ensure Next.js runs with --hostname 0.0.0.0 (default in dev).
# If you keep localhost here and open the magic link on a phone, you may get "Unexpected error" after clicking the link.
AUTH_URL='http://localhost:3000'

# Discord OAuth (optional — configure at https://discord.com/developers/applications)
# @see https://www.better-auth.com/docs/authentication/discord
AUTH_DISCORD_ID=''
AUTH_DISCORD_SECRET=''

# Magic link email (Resend — https://resend.com)
RESEND_KEY='re_xxxx'
RESEND_FROM_EMAIL='Prikkr <onboarding@resend.dev>'

# Google OAuth (optional — configure at https://console.cloud.google.com)
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''

# Apple Sign In (optional — Apple Developer Portal; requires HTTPS in production)
# @see https://www.better-auth.com/docs/authentication/apple
AUTH_APPLE_CLIENT_ID=''
AUTH_APPLE_CLIENT_SECRET=''
AUTH_APPLE_BUNDLE_ID=''

# Supabase project credentials (for Realtime and Storage)
# Find in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL='https://[project-ref].supabase.co'
NEXT_PUBLIC_SUPABASE_ANON_KEY=''
# Service role key (server-only) for recipe image uploads and profile image uploads.
# Create storage buckets in Supabase Dashboard → Storage:
# - "recipe-images" (public) for recipe photos
# - "profile-images" (public) for profile photos — enable "Allow signed uploads" or use RLS
SUPABASE_SERVICE_ROLE_KEY=''

# Expo public variables (exposed to the React Native client)
# Use the same URL as AUTH_URL when testing magic link on a real device (e.g. http://192.168.1.100:3000)
EXPO_PUBLIC_API_URL='http://localhost:3000'
# Optional: Supabase URL and anon key for Realtime (grocery list live updates). Same as Next.js public vars.
EXPO_PUBLIC_SUPABASE_URL='https://[project-ref].supabase.co'
EXPO_PUBLIC_SUPABASE_ANON_KEY=''
# EAS project ID for push notifications (Expo Dashboard → project settings)
EXPO_PUBLIC_EAS_PROJECT_ID=''

# Privacy policy URL (opened from Instellingen → Privacybeleid and onboarding)
EXPO_PUBLIC_PRIVACY_URL=''
# Terms of use URL (opened from onboarding welcome screen)
EXPO_PUBLIC_TERMS_URL=''

# Cron: secret for protecting /api/cron/* endpoints (e.g. Vercel Cron sends Authorization: Bearer <secret>)
CRON_SECRET=''

# OpenAI (voor ingredient normalisatie via GPT-4o-mini)
OPENAI_API_KEY=''
