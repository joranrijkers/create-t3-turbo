{
  "name": "@prikkr/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev --hostname 0.0.0.0",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@prikkr/api": "workspace:*",
    "@prikkr/auth": "workspace:*",
    "@prikkr/db": "workspace:*",
    "@prikkr/ui": "workspace:*",
    "@prikkr/validators": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "expo-server-sdk": "^3.10.0",
    "next": "^16.0.9",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "resend": "^4.0.0",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@prikkr/eslint-config": "workspace:*",
    "@prikkr/prettier-config": "workspace:*",
    "@prikkr/tailwind-config": "workspace:*",
    "@prikkr/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "eslint": "catalog:",
    "jiti": "^2.5.1",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  },
  "prettier": "@prikkr/prettier-config"
}
